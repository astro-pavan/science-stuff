\ProvidesPackage{beamerthemeCambridgeUK}

\RequirePackage{tikz}
\RequirePackage{xparse}

%\RequirePackage[default]{sourcesanspro} % A very clean, modern alternative to Verdana
\RequirePackage[light]{raleway}
\RequirePackage[T1]{fontenc}


\mode<presentation>

% --- 1. DEFINE TOGGLES (Defaults are OFF) ---
\newif\if@showheader
\@showheaderfalse

\newif\if@shownav
\@shownavfalse

\newif\if@autosec
\@autosecfalse

% Background image defaults
\def\@bgimagepath{}
\def\@bgopacity{0.3}
\def\@bgcrop{l}

% --- 2. LISTEN FOR PARAMETERS ---
\DeclareOptionBeamer{color}{\def\mythemecolorval{#1}}
\DeclareOptionBeamer{header}{\@showheadertrue}
\DeclareOptionBeamer{nav}{\@shownavtrue}
\DeclareOptionBeamer{autosec}{\@autosectrue}
\DeclareOptionBeamer{bgimage}{\def\@bgimagepath{#1}}
\DeclareOptionBeamer{bgopacity}{\def\@bgopacity{#1}}
\DeclareOptionBeamer{bgcrop}{\def\@bgcrop{#1}}

% --- 3. SET DEFAULT COLOR AND PROCESS ---
\ExecuteOptionsBeamer{color={0, 80, 150}}
\ProcessOptionsBeamer

% Save global bg image settings so \clearbgimage can restore them
\edef\@globalbgimagepath{\@bgimagepath}
\edef\@globalbgopacity{\@bgopacity}
\edef\@globalbgcrop{\@bgcrop}

% --- 4. APPLY THE COLOR ---
\definecolor{mainthemecolor}{RGB}{\mythemecolorval}

\usefonttheme{professionalfonts}

\useinnertheme[shadow=true]{rounded}
\useoutertheme{infolines}
\usecolortheme{beaver}

\setbeamerfont{block title}{size={}}

\setbeamercolor{palette primary}{bg=mainthemecolor,fg=white}
\setbeamercolor{palette secondary}{bg=mainthemecolor!75,fg=white}
\setbeamercolor{palette tertiary}{bg=mainthemecolor!50,fg=white}
\setbeamercolor{titlelike}{bg=white,fg=mainthemecolor}
\setbeamercolor{item}{fg=mainthemecolor}

\if@showheader
\else
\setbeamertemplate{headline}{} 
\fi

\if@shownav
\else
\setbeamertemplate{navigation symbols}{} 
\fi

% ---------------------------------------------------
% Environment: Per-Slide Dark Mode wrapper
% ---------------------------------------------------
\newenvironment{darkslide}{
    % 1. Flip standard Beamer colors to dark
    \setbeamercolor{normal text}{bg=black!95, fg=white}
    \setbeamercolor{background canvas}{bg=black!95}

   \setbeamertemplate{background canvas}{%
        \begin{tikzpicture}[remember picture, overlay]
            % 1. Fill the base color (Dark Gray)
            \fill[black!95] (current page.south west) rectangle (current page.north east);
            
            % 2. Draw the background image if one is set
            \ifx\@bgimagepath\@empty\else
                \clip (current page.south west) rectangle (current page.north east);
                
                \def\fbi@croplandscape{l}%
                \ifx\@bgcrop\fbi@croplandscape
                    \node[inner sep=0pt, opacity=\@bgopacity, anchor=center] at (current page.center) {%
                        \includegraphics[height=\paperheight]{\@bgimagepath}%
                    };
                \else
                    \node[inner sep=0pt, opacity=\@bgopacity, anchor=center] at (current page.center) {%
                        \includegraphics[width=\paperwidth]{\@bgimagepath}%
                    };
                \fi
            \fi
        \end{tikzpicture}%
    }%

    % 2. Flip titles and headers
    \setbeamercolor{frametitle}{bg=black!75, fg=white}
    \setbeamercolor{title}{bg=black!95, fg=white}
    \setbeamercolor{titlelike}{bg=black!95, fg=white}
    
    % 3. Flip the CambridgeUS footer elements
    \setbeamercolor{author in head/foot}{bg=black!85, fg=white}
    \setbeamercolor{title in head/foot}{bg=black!95, fg=white}
    \setbeamercolor{date in head/foot}{bg=black!85, fg=white}
    
    % 4. Flip translucent TikZ box color variables (used by \coversplitframe)
    \colorlet{transboxbg}{black!85}
    \colorlet{transboxtext}{white}

    % 5. Force LaTeX to immediately apply the new text color
    \usebeamercolor[fg]{normal text}
}{
    \@setlightbgcanvas
}

\setbeamertemplate{itemize items}[circle]

% ---------------------------------------------------
% Background Image
% \setbgimage[crop]{path}{opacity} -- set for subsequent frames ('l' landscape, 'p' portrait)
% \clearbgimage                    -- restore global default (or no image if none set globally)
% ---------------------------------------------------
\newcommand{\setbgimage}[3][l]{%
    \def\@bgimagepath{#2}%
    \def\@bgopacity{#3}%
    \def\@bgcrop{#1}%
}
\newcommand{\clearbgimage}{%
    \edef\@bgimagepath{\@globalbgimagepath}%
    \edef\@bgopacity{\@globalbgopacity}%
    \edef\@bgcrop{\@globalbgcrop}%
}

% Stored as a command so darkslide's end hook can restore it
\newcommand{\@setlightbgcanvas}{%
    \setbeamertemplate{background canvas}{%
        \begin{tikzpicture}[remember picture, overlay]
            % 1. Always fill the base color (White) to prevent transparency bugs
            \fill[white] (current page.south west) rectangle (current page.north east);
            
            % 2. Draw the background image if one is set
            \ifx\@bgimagepath\@empty\else
                % Clip to the screen edges so wide images don't overflow the PDF
                \clip (current page.south west) rectangle (current page.north east);
                
                \def\fbi@croplandscape{l}%
                \ifx\@bgcrop\fbi@croplandscape
                    \node[inner sep=0pt, opacity=\@bgopacity, anchor=center] at (current page.center) {%
                        \includegraphics[height=\paperheight]{\@bgimagepath}%
                    };
                \else
                    \node[inner sep=0pt, opacity=\@bgopacity, anchor=center] at (current page.center) {%
                        \includegraphics[width=\paperwidth]{\@bgimagepath}%
                    };
                \fi
            \fi
        \end{tikzpicture}%
    }%
}
\@setlightbgcanvas

% Default colors for \coversplitframe translucent box (overridden by darkslide)
\colorlet{transboxbg}{white}
\colorlet{transboxtext}{black}

% ---------------------------------------------------
% Template: Centered Image Slide
% #1 (Optional): Frame title
% #2: Image path
% ---------------------------------------------------
\newcommand{\imageframe}[2][]{
	\begin{frame}{#1}
		\vspace{-0.5em} % Slight adjustment to center visually between bars
		\begin{center}
			% Scales the image to fit available space without distorting
			\includegraphics[width=\textwidth, height=0.8\textheight, keepaspectratio]{#2}
		\end{center}
	\end{frame}
}

% ---------------------------------------------------
% Template: Full Screen Cover Image (TikZ Engine)
% \coverframe[crop]{image}  -- no bars (default)
% \coverframe*[crop]{image} -- with header/footer bars
% crop: l = fit by height (landscape), p = fit by width (portrait)
% ---------------------------------------------------
\NewDocumentCommand{\coverframe}{s O{l} m}{
	\def\croplandscape{l}
	\def\usercrop{#2}
	\IfBooleanTF{#1}{\begin{frame}}{\begin{frame}[plain]}
		\begin{tikzpicture}[remember picture, overlay]
			\ifx\usercrop\croplandscape
			\node[inner sep=0pt, anchor=center] at (current page.center) {
				\includegraphics[height=\paperheight]{#3}
			};
			\else
			\node[inner sep=0pt, anchor=center] at (current page.center) {
				\includegraphics[width=\paperwidth]{#3}
			};
			\fi
		\end{tikzpicture}
	\end{frame}
}

% ---------------------------------------------------
% Template: Split Frame (Image and Text side-by-side)
% #1 (Optional): Image Column Width (Defaults to 0.45\textwidth)
% #2: Image Position ('l' for left, 'r' for right)
% #3: Title
% #4: Image Path
% #5: Text Content
% ---------------------------------------------------
\newcommand{\splitframe}[5][0.45\textwidth]{
	\def\alignleft{l}
	\def\useralign{#2}

	\ifx\useralign\alignleft
	% --- IMAGE ON THE LEFT ---
	\begin{frame}{#3}
		\begin{columns}[c, onlytextwidth]
			\begin{column}{#1}
				\includegraphics[width=\textwidth, keepaspectratio]{#4}
			\end{column}
			\begin{column}{\dimexpr\textwidth-#1-0.05\textwidth\relax}
				#5
			\end{column}
		\end{columns}
	\end{frame}
	
	\else
	% --- IMAGE ON THE RIGHT ---
	\begin{frame}{#3}
		\begin{columns}[c, onlytextwidth]
			\begin{column}{\dimexpr\textwidth-#1-0.05\textwidth\relax}
				#5
			\end{column}
			\begin{column}{#1}
				\includegraphics[width=\textwidth, keepaspectratio]{#4}
			\end{column}
		\end{columns}
	\end{frame}
	\fi
}

% ---------------------------------------------------
% Template: Text Only
% #1: Title, #2: Text Content
% ---------------------------------------------------
\newcommand{\textframe}[2]{
	\begin{frame}{#1}
		#2
	\end{frame}
}

% ---------------------------------------------------
% Template: Plain Title Slide
% #1 (Optional): Path to institutional logo
% ---------------------------------------------------
\newcommand{\titleframe}[1][]{
	\begin{frame}[plain]
		\vfill
		\begin{center}
			% Title & Subtitle
			{\usebeamercolor[fg]{titlelike}\LARGE{\inserttitle}\par}
			
			\vskip0.5em
			{\color{mainthemecolor}\hrule height 0.5pt}
			
			\ifx\insertsubtitle\@empty\else
			\vskip0.6em
			{\large\insertsubtitle\par}
			\fi
			
			\vskip1.5em
			
			% Author, Institute, Date
			{\large\insertauthor\par}
			\vskip0.5em
			{\small\insertinstitute\par}
			\vskip0.5em
			{\small\insertdate\par}
			
			% Optional Logo Logic
			\if\relax\detokenize{#1}\relax
			% No logo provided, do nothing
			\else
			\vskip1.5em
			\includegraphics[height=1.5cm, keepaspectratio]{#1}
			\fi
		\end{center}
		\vfill
	\end{frame}
}

% ---------------------------------------------------
% Template: Image Title Slide (TikZ Engine)
% #1 (Optional): Banner position (north or south). Defaults to south.
% #2: Image Crop Mode ('l' for landscape, 'p' for portrait)
% #3: Image Path
% ---------------------------------------------------
\newcommand{\imagetitleframe}[3][south]{
	\def\croplandscape{l}
	\def\usercrop{#2}
	
	\begin{frame}[plain]
		% --- 1. DRAW BACKGROUND IMAGE ---
		\begin{tikzpicture}[remember picture, overlay]
			\ifx\usercrop\croplandscape
			\node[inner sep=0pt, anchor=center] at (current page.center) {
				\includegraphics[height=\paperheight]{#3}
			};
			\else
			\node[inner sep=0pt, anchor=center] at (current page.center) {
				\includegraphics[width=\paperwidth]{#3}
			};
			\fi
		\end{tikzpicture}
		
		% --- 2. DRAW TRANSPARENT BANNER ---
		\begin{tikzpicture}[remember picture, overlay]
			\node[fill=mainthemecolor, fill opacity=0.6, text opacity=1, minimum width=\paperwidth, anchor=#1, inner ysep=20pt] at (current page.#1) {
				\begin{minipage}{\textwidth}
					\centering
					\color{white} 
					{\LARGE\inserttitle\par}
					
					\ifx\insertsubtitle\@empty\else
					\vskip0.5em
					{\normalsize\insertsubtitle\par}
					\fi
					\vskip1em
					{\normalsize\insertauthor\par}
				\end{minipage}
			};
		\end{tikzpicture}
	\end{frame}
}

% ---------------------------------------------------
% Template: Floating Textbox over Full Screen Image (TikZ Engine)
% \coversplitframe[width]{align}{crop}{title}{image}{content}  -- no bars (default)
% \coversplitframe*[width]{align}{crop}{title}{image}{content} -- with header/footer bars
% ---------------------------------------------------
\NewDocumentCommand{\coversplitframe}{s O{0.45\paperwidth} m m m m m}{
	\def\alignleft{l}
	\def\useralign{#3}
	\def\croplandscape{l}
	\def\usercrop{#4}
	\def\notitle{}
	\def\usertitle{#5}

	\IfBooleanTF{#1}{\begin{frame}}{\begin{frame}[plain]}
		% --- 1. DRAW BACKGROUND IMAGE ---
		\begin{tikzpicture}[remember picture, overlay]
			\ifx\usercrop\croplandscape
			\node[inner sep=0pt, anchor=center] at (current page.center) {
				\includegraphics[height=\paperheight]{#6}
			};
			\else
			\node[inner sep=0pt, anchor=center] at (current page.center) {
				\includegraphics[width=\paperwidth]{#6}
			};
			\fi
		\end{tikzpicture}

		% --- 2. DRAW FLOATING TEXTBOX ---
		\begin{tikzpicture}[remember picture, overlay]
			\ifx\useralign\alignleft
			\node[fill=transboxbg, fill opacity=0.7, text opacity=1, rounded corners=5pt, anchor=west, inner sep=15pt] at ([xshift=15pt]current page.west) {
				\begin{minipage}{#2}
					\color{transboxtext}
					\ifx\usertitle\notitle\else
					{\usebeamercolor[fg]{titlelike}\LARGE #5\par}
					\vspace{0.4em}
					{\color{mainthemecolor}\rule{0.8\textwidth}{0.4pt}}\par
					\vspace{1.5em}
					\fi
					#7
				\end{minipage}
			};
			\else
			\node[fill=transboxbg, fill opacity=0.7, text opacity=1, rounded corners=5pt, anchor=east, inner sep=15pt] at ([xshift=-15pt]current page.east) {
				\begin{minipage}{#2}
					\color{transboxtext}
					\ifx\usertitle\notitle\else
					{\usebeamercolor[fg]{titlelike}\LARGE #5\par}
					\vspace{0.4em}
					{\color{mainthemecolor}\rule{0.8\textwidth}{0.4pt}}\par
					\vspace{1.5em}
					\fi
					#7
				\end{minipage}
			};
			\fi
		\end{tikzpicture}
	\end{frame}
}

% ---------------------------------------------------
% Template: Section Divider Slide
% #1: Section Title
% #2: Subtitle / Description (Leave empty {} for none)
% ---------------------------------------------------
\newcommand{\sectionframe}[2]{
    \begin{frame}[plain]
        \vfill
        \begin{center}
            % Main Section Title
            {\usebeamercolor[fg]{titlelike}\LARGE #1\par}
            \vspace{0.4em}
            
            % Thin horizontal line
            {\color{mainthemecolor}\rule{0.3\textwidth}{0.4pt}}\par
            
            % Subtitle logic
            \def\emptysub{}
            \def\usersub{#2}
            \ifx\usersub\emptysub\else
                \vspace{1em}
                {\usebeamercolor[fg]{normal text}\large #2\par}
            \fi
        \end{center}
        \vfill
    \end{frame}
}

% ---------------------------------------------------
% Template: Subsection Divider Slide
% #1: Parent Section Name (To give the audience context)
% #2: Subsection Name
% ---------------------------------------------------
\newcommand{\subsectionframe}[2]{
    \begin{frame}[plain]
        \vfill
        \begin{center}
            % Tiny Parent Section Title
            {\usebeamercolor[fg]{normal text}\normalsize #1\par}
            \vspace{0.2em}
            
            % Very short thin line
            {\color{mainthemecolor}\rule{0.1\textwidth}{0.4pt}}\par
            \vspace{0.8em}
            
            % Main Subsection Title
            {\usebeamercolor[fg]{titlelike}\Large #2\par}
        \end{center}
        \vfill
    \end{frame}
}

\if@autosec
    \AtBeginSection[]{\sectionframe{\insertsectionhead}{}}
\fi

\mode
<all>